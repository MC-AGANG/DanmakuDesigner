<UserControl x:Class="Button"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AgControls"
             mc:Ignorable="d" 
             d:DesignHeight="48" d:DesignWidth="64"
             Background="#01FFFFFF"
             MouseUp="UserControl_MouseUp"
             MouseDown="UserControl_MouseDown"
             MouseEnter="UserControl_MouseEnter"
             MouseLeave="UserControl_MouseLeave">
    <Grid>
        <Rectangle Name="RC_Icon" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Label Name="LB_Text" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
    </Grid>
</UserControl>
