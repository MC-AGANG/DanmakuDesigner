<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:DanmakuDesigner"
        xmlns:AGC="clr-namespace:AgControls;assembly=AgControls"
        xmlns:RS="clr-namespace:ResourcePack.DD;assembly=ResourcePack.DD"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        >
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                           ResizeBorderThickness="8"
                           GlassFrameThickness="0"
                           />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Rectangle Stroke="#FF007ACC" Margin="7" Name="borderall"></Rectangle>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="8"/>
                <RowDefinition/>
                <RowDefinition Height="8"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8"/>

                <ColumnDefinition/>

                <ColumnDefinition Width="8"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="7"
                    Grid.Column="2" 
                    Grid.ColumnSpan="2" 
                    Background="#FF1E1E1E">
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.ColumnSpan="1" Cursor="SizeNS" Name="bordern">
                <DockPanel Height="8">
                    <DockPanel.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#00007ACC" Offset="0"/>
                            <GradientStop Color="#60007ACC" Offset="1"/>
                        </LinearGradientBrush>
                    </DockPanel.Background>
                </DockPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.ColumnSpan="1" Cursor="SizeNS" Grid.Row="2" Name="borders">
                <DockPanel Height="8" Name="borders_">
                    <DockPanel.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#00007ACC" Offset="1"/>
                            <GradientStop Color="#60007ACC" Offset="0"/>
                        </LinearGradientBrush>
                    </DockPanel.Background>
                </DockPanel>
            </StackPanel>
            <StackPanel Cursor="SizeWE" Grid.Row="1" Name="borderw" Grid.RowSpan="1" Orientation="Horizontal">
                <DockPanel Width="8">
                    <DockPanel.Background>
                        <LinearGradientBrush EndPoint="0,0.5" StartPoint="1,0.5">
                            <GradientStop Color="#00007ACC" Offset="1"/>
                            <GradientStop Color="#60007ACC" Offset="0"/>
                        </LinearGradientBrush>
                    </DockPanel.Background>
                </DockPanel>
            </StackPanel>
            <StackPanel Cursor="SizeWE" Grid.Row="1" Name="bordere" Grid.RowSpan="1" Orientation="Horizontal" Grid.Column="2">
                <DockPanel Width="8">
                    <DockPanel.Background>
                        <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                            <GradientStop Color="#00007ACC" Offset="1"/>
                            <GradientStop Color="#60007ACC" Offset="0"/>
                        </LinearGradientBrush>
                    </DockPanel.Background>
                </DockPanel>
            </StackPanel>
            <StackPanel Name="bordernw" Cursor="SizeNWSE">
                <StackPanel.Background>
                    <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                        <GradientStop Color="#00007ACC" Offset="0.5"/>
                        <GradientStop Color="#60007ACC" Offset="1"/>
                    </LinearGradientBrush>
                </StackPanel.Background>
            </StackPanel>
            <StackPanel Name="borderse" Cursor="SizeNWSE" Grid.Row="2" Grid.Column="3">
                <StackPanel.Background>
                    <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                        <GradientStop Color="#00007ACC" Offset="0.5"/>
                        <GradientStop Color="#60007ACC" Offset="0"/>
                    </LinearGradientBrush>
                </StackPanel.Background>
            </StackPanel>
            <StackPanel Name="borderne" Cursor="SizeNESW" Grid.Column="2">
                <StackPanel.Background>
                    <LinearGradientBrush EndPoint="1,0" StartPoint="0,1">
                        <GradientStop Color="#00007ACC" Offset="0.5"/>
                        <GradientStop Color="#60007ACC" Offset="0"/>
                    </LinearGradientBrush>
                </StackPanel.Background>
            </StackPanel>
            <StackPanel Name="bordersw" Cursor="SizeNESW" Grid.Row="2">
                <StackPanel.Background>
                    <LinearGradientBrush EndPoint="1,0" StartPoint="0,1">
                        <GradientStop Color="#00007ACC" Offset="0.5"/>
                        <GradientStop Color="#60007ACC" Offset="1"/>
                    </LinearGradientBrush>
                </StackPanel.Background>
            </StackPanel>
            <Grid Grid.Row="1" Grid.Column="1" Background="#FF2D2D30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="192"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Fill="#FF2D2D30" MouseDown="Rectangle_MouseDown"/>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="38" Fill="{x:Static RS:Textures.Logo_w}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <AGC:Button Width="64" Name="BT_Minimize" Icon="{x:Static RS:Textures.BT_Minimize}" Clicked="BT_Minimize_Clicked" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <AGC:Button Width="64" Name="BT_Maximize" Icon="{x:Static RS:Textures.BT_Maximize}" Clicked="BT_Maximize_Clicked" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <AGC:Button Width="64" Name="BT_Close" Icon="{x:Static RS:Textures.BT_Close}" Clicked="BT_Close_Clicked" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
